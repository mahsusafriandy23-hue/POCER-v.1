# Copy to .env and adjust. NEVER commit real secrets.
# Isolated dev DB (use docker-compose up -d to get a local Postgres).
DATABASE_URL="postgresql://voucher:voucher@localhost:5432/voucher_platform?schema=public"

# API
PORT=8080
API_PREFIX=api/v1
NODE_ENV=development

# Payment provider selection: "sim" (default, no external deps) | "gobiz" (real EMV QR build)
PAYMENT_PROVIDER=sim
# Static EMV QRIS template for the "gobiz" provider. If empty, a SYNTHETIC template is used
# (QR builds correctly but is not a real merchant). Supply YOUR merchant QRIS to go live.
QRIS_TEXT=

# Payment DETECTION (pull-based reconciliation): "sim" (in-memory, default) | "gobiz"
DETECTION_PROVIDER=sim
DETECTION_WINDOW_MS=3600000     # lookback window for settlements
DETECTION_GRACE_MS=60000        # extra grace before marking an unmatched payment EXPIRED
# Only for DETECTION_PROVIDER=gobiz — your authenticated journals/search endpoint (or a mock).
DETECTION_GATEWAY_URL=
DETECTION_GATEWAY_KEY=
DETECTION_GATEWAY_TIMEOUT_MS=10000

# Background scheduler: auto-run reconciliation + lock cleanup. Off by default.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MS=30000

# Encryption key for secrets at rest (per-server router passwords). Set a long random value in prod.
APP_ENCRYPTION_KEY=
# Admin API shared key (header X-Admin-Key) for /admin/* endpoints. Empty = admin API disabled.
ADMIN_API_KEY=
# Payment window (ms). Mirrors legacy BATAS_WAKTU_BAYAR (production = 3600000 = 1h).
PAYMENT_TTL_MS=3600000

# Webhook HMAC secret (mirrors legacy WEBHOOK_SECRET). Dev value only.
WEBHOOK_SECRET=dev-secret-change-me

# Provisioning provider: "sim" (default) | "routeros" (real RouterOS API)
PROVISIONING_PROVIDER=sim
# Only for PROVISIONING_PROVIDER=routeros — a TEST router or the mock (scripts/mock-routeros.js).
# NEVER a production router without explicit approval.
ROUTEROS_HOST=127.0.0.1
ROUTEROS_PORT=8728
ROUTEROS_USER=admin
ROUTEROS_PASS=
ROUTEROS_TIMEOUT_MS=8000

# Notification provider: "sim" (default, logs) | "whatsapp" (real ACL → Baileys-style gateway)
NOTIFICATION_PROVIDER=sim
# Only used when NOTIFICATION_PROVIDER=whatsapp. Point at YOUR gateway (never a prod one by default).
NOTIFICATION_GATEWAY_URL=
NOTIFICATION_GATEWAY_KEY=
NOTIFICATION_GATEWAY_TIMEOUT_MS=8000
