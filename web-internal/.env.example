# POCER Internal Console — environment

# Base path for API calls. With the built-in next rewrite proxy, keep "/api/v1"
# (same-origin) and point BACKEND_ORIGIN at the NestJS backend.
NEXT_PUBLIC_API_BASE=/api/v1
BACKEND_ORIGIN=http://localhost:8080

# Login surface this deployment exposes:
#   agent → only the Agen login (public surface, e.g. agen.pocer.net)
#   owner → only the Pemilik login (PROTECT this deploy: separate subdomain +
#           Cloudflare Access / IP allowlist, e.g. admin.pocer.net)
#   both  → role toggle (local dev / single deploy)
NEXT_PUBLIC_APP_MODE=both

# Set to 1 to show the "Simulasikan Pembayaran (demo)" button on QRIS panes.
NEXT_PUBLIC_DEMO=1
